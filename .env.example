# ─────────────────────────────────────────────────────────────────────────────
# Supabase — one project per environment (dev / staging / prod).
# Copy this file to `.env` (or `.env.local`) and fill in the values for the
# environment you are running against. NEVER commit a real `.env`.
#
# The frontend only ever uses the PUBLIC anon key. It reaches Supabase through
# RLS-protected reads and Edge Functions only. The service_role key and any AI
# or payment provider secrets live exclusively in Edge Function environment
# variables on the server — they must never appear in this file or the bundle.
# ─────────────────────────────────────────────────────────────────────────────

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
